{
  "indentWidth": 2,
  "lineWidth": 80,
  "markdown": {
    "textWrap": "maintain",
    "emphasisKind": "asterisks",
    "strongKind": "asterisks",
    "unorderedListKind": "dashes"
  },
  "includes": [
    "articles/**/*.md",
    "books/**/*.md",
    "README.md",
    "CLAUDE.md"
  ],
  "excludes": [
    "**/node_modules",
    "**/.git"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.21.1.wasm"
  ]
}
